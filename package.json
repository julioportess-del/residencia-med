{
  "name": "residencia-med",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "db:migrate": "pnpm --filter @residencia-med/db db:migrate",
    "db:seed": "pnpm --filter @residencia-med/db db:seed",
    "db:studio": "pnpm --filter @residencia-med/db db:studio",
    "db:reset": "pnpm --filter @residencia-med/db db:reset",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "prettier": "^3.3.3",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "18.3.12",
      "@types/react-dom": "18.3.1",
      "react": "18.3.1",
      "react-dom": "18.3.1"
    }
  }
}
